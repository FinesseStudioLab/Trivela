    "supertest": "^7.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.7.0",
    "@types/supertest": "^7.2.0",
    "typescript": "^6.0.3",
    "js-yaml": "^4.1.0",
    "ajv": "^8.17.0",
    "@readme/openapi-parser": "^6.1.1"
